{
  "embedding_provider_id": {
    "description": "Embedding 服务提供商",
    "type": "string",
    "_special": "select_embedding_provider",
    "hint": "用于工作记忆向量化的 Embedding Provider，留空则使用默认",
    "default": ""
  },
  "llm_provider_id": {
    "description": "工作记忆/TLDR/图谱 LLM Provider",
    "type": "string",
    "_special": "select_provider",
    "hint": "用于工作记忆、每日 TLDR 与图谱抽取的模型提供商，留空使用当前会话提供商",
    "default": ""
  },
  "milvus": {
    "description": "Milvus 向量数据库配置",
    "type": "object",
    "items": {
      "lite_path": {
        "description": "Milvus Lite 数据路径",
        "type": "string",
        "hint": "优先使用 Milvus Lite，本地路径或相对路径（相对插件数据目录）",
        "default": "milvus/flomemo.db"
      },
      "address": {
        "description": "Milvus 服务地址",
        "type": "string",
        "hint": "支持 http(s)://host:port 或 host:port，留空则使用 127.0.0.1:19530",
        "default": ""
      },
      "db_name": {
        "description": "Milvus 数据库名称",
        "type": "string",
        "default": "default"
      },
      "user": {
        "description": "Milvus 用户名",
        "type": "string",
        "default": ""
      },
      "password": {
        "description": "Milvus 密码",
        "type": "string",
        "default": ""
      },
      "token": {
        "description": "Milvus Token",
        "type": "string",
        "default": ""
      },
      "secure": {
        "description": "Milvus 使用 TLS",
        "type": "bool",
        "default": false
      },
      "collection": {
        "description": "工作记忆集合名称",
        "type": "string",
        "default": "flomemo_working_memory"
      }
    }
  },
  "working_memory": {
    "description": "工作记忆配置",
    "type": "object",
    "items": {
      "retention_days": {
        "description": "工作记忆保留天数",
        "type": "int",
        "default": 3,
        "minimum": 1,
        "maximum": 30
      },
      "working_memory_top_k": {
        "description": "工作记忆召回条数",
        "type": "int",
        "default": 5,
        "minimum": 1,
        "maximum": 20
      },
      "working_memory_batch_size": {
        "description": "工作记忆总结触发阈值（对话轮数）",
        "type": "int",
        "hint": "每 N 轮对话（用户+机器人）生成一次工作记忆摘要",
        "default": 5,
        "minimum": 1,
        "maximum": 50
      },
      "working_memory_summary_prompt": {
        "description": "工作记忆总结提示词",
        "type": "text",
        "default": "请将以下对话内容压缩成一段可检索的工作记忆摘要。要求：\\n1) 保留关键人物、事件、时间、结论与约束；\\n2) 保留重要数字/数量/规格；\\n3) 使用简洁自然语言，不分点；\\n4) 不引入臆测与解释。\\n\\n对话内容：\\n{content}"
      }
    }
  },
  "summary": {
    "description": "每日摘要配置",
    "type": "object",
    "items": {
      "summary_time": {
        "description": "每日 TLDR 生成时间",
        "type": "string",
        "hint": "24 小时制 HH:MM",
        "default": "23:50",
        "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
      },
      "summary_timezone": {
        "description": "每日 TLDR 时区",
        "type": "string",
        "hint": "IANA 时区名称，如 Asia/Shanghai；留空则使用系统时区",
        "default": ""
      },
      "summary_min_messages": {
        "description": "生成 TLDR 的最小原始消息条数",
        "type": "int",
        "default": 6,
        "minimum": 1,
        "maximum": 200
      },
      "summary_min_turns": {
        "description": "生成 TLDR 的最小原始对话轮数",
        "type": "int",
        "hint": "按工作记忆摘要附带的 source_turn_count 统计，设为 0 表示不限制",
        "default": 0,
        "minimum": 0,
        "maximum": 100
      },
      "summary_prompt": {
        "description": "TLDR 提示词",
        "type": "text",
        "default": "请基于以下对话内容生成一段 TL;DR，总结当天的核心信息。要求：\\n1) 使用一段简洁自然语言，不分点；\\n2) 强调人物、事件、时间、关键决定与结果；\\n3) 保留关键数字/数量/规格；\\n4) 不添加臆测与解释。\\n\\n对话内容：\\n{content}"
      },
      "summary_injection_days": {
        "description": "注入摘要的最近天数",
        "type": "int",
        "default": 7,
        "minimum": 1,
        "maximum": 30
      }
    }
  },
  "graph": {
    "description": "知识图谱配置",
    "type": "object",
    "items": {
      "graph_enabled": {
        "description": "启用知识图谱",
        "type": "bool",
        "default": true
      },
      "graph_max_edges": {
        "description": "注入图谱边数量",
        "type": "int",
        "default": 6,
        "minimum": 0,
        "maximum": 50
      },
      "graph_query_limit": {
        "description": "图谱查询返回条数",
        "type": "int",
        "default": 10,
        "minimum": 1,
        "maximum": 50
      },
      "graph_min_confidence": {
        "description": "图谱最小置信度",
        "type": "float",
        "hint": "低于该值的边不会参与查询结果，范围 0 到 1",
        "default": 0.35,
        "minimum": 0,
        "maximum": 1
      },
      "graph_prompt": {
        "description": "知识图谱抽取提示词",
        "type": "text",
        "default": "请从以下 TL;DR 中抽取人物关系、事件因果与关键事实，输出 JSON 数组。每个元素包含：source, relation, target, type, evidence, confidence。\\nconfidence 为 0 到 1 的浮点数，表示该关系的可信度。\\n仅输出 JSON，不要额外说明。\\n\\nTL;DR：\\n{summary}"
      }
    }
  },
  "memory_injection": {
    "description": "注入记忆到对话",
    "type": "bool",
    "default": true
  },
  "memory_injection_max_chars": {
    "description": "记忆注入最大长度",
    "type": "int",
    "hint": "限制注入到 system_prompt / user_prompt 的总字符数，超出时按相关度与新鲜度裁剪",
    "default": 1800,
    "minimum": 300,
    "maximum": 12000
  },
  "memory_injection_target": {
    "description": "记忆注入位置",
    "type": "string",
    "options": ["system_prompt", "user_prompt"],
    "default": "system_prompt"
  }
}
